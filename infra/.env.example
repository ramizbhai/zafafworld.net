# ==============================================================================
# ZafafWorld Infrastructure Configurations (Safe Template)
# ==============================================================================

# Production deployment root directory on host
DEPLOY_ROOT="/opt/zafafworld.net"

# Target systemd service name for application
SERVICE_NAME="zafafworld.service"

# Host path for shared media uploads
UPLOADS_VOLUME_DIR="/var/lib/zafafworld/uploads"

# Host path for db & volume backups
BACKUP_DIR="/opt/zafafworld.net/backups"

# Retain backups for N days
BACKUP_RETAIN_DAYS=14

# API target endpoint for post-deployment health checks
API_BASE_URL="http://127.0.0.1:8080"

# MinIO storage service parameters
MINIO_ENDPOINT="http://localhost:9000"
MINIO_BUCKET="zafafworld-media"

# Test JWT signature key for simulation regressions (DO NOT use production key here)
TEST_JWT_SECRET="your_secure_test_jwt_secret_key_minimum_64_bytes_long"
