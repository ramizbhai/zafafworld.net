# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — ZafafWorld Template Environment Configurations
# ═══════════════════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=zafafworld
APP_ENVIRONMENT=production

# ── PostgreSQL Database Configurations ────────────────────────────────────────
POSTGRES_DB=zafaf_world
POSTGRES_USER=zafaf_db_admin
POSTGRES_PASSWORD=PASSWORD
DATABASE_URL=postgres://zafaf_db_admin:PASSWORD@127.0.0.1:5434/zafaf_world

# ── JWT Security ──────────────────────────────────────────────────────────────
JWT_SECRET=daa9378d0ba52549d3aafc36a140ca89c27d2c51bfacbddea6edfe94db3254065fb904ec316e787fdf0113bb5e9a97c2607cbace8a2e5c0d0185c99f27a9c53e
JWT_EXPIRES_IN=7d

# ── SMTP Hostinger Mail Configurations ────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=services@zafafworld.net
SMTP_PASSWORD=Zafaf123$
SMTP_FROM_EMAIL=services@zafafworld.net
SMTP_FROM_NAME=ZafafWorld
SMTP_TLS_MODE=implicit
SMTP_TIMEOUT_SECONDS=10

# ── Application URLs and CORS Origins ─────────────────────────────────────────
CORS_ORIGINS="https://zafafworld.net, https://vendor.zafafworld.net, https://admin.zafafworld.net"
FRONTEND_URL=https://zafafworld.net
PUBLIC_API_URL=https://api.zafafworld.net
PUBLIC_WS_URL=wss://api.zafafworld.net
PUBLIC_CLIENT_URL=https://zafafworld.net
PUBLIC_VENDOR_URL=https://vendor.zafafworld.net
PUBLIC_ADMIN_URL=https://admin.zafafworld.net

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
RUST_LOG_FORMAT=json

# ── Database Boot Seed Credentials ───────────────────────────────────────────
ADMIN_INITIAL_EMAIL=admin@zafafworld.net
ADMIN_INITIAL_PASSWORD=Zafafworld@2026
AFRAH_DISPLAY_NAME=Afrah
BLOG_TRACKING_ENABLED=true

# ── WhatsApp API Settings ─────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_VERSION=v18.0
WHATSAPP_TEMPLATE_NEW_INQUIRY=new_inquiry_alert
WHATSAPP_LANGUAGE=en
HTTP_TIMEOUT_SECONDS=10

# ── Outbox Pipeline Settings ──────────────────────────────────────────────────
OUTBOX_BATCH_SIZE=5
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_CLEANUP_INTERVAL_SECS=300
OUTBOX_MAX_RETRIES=5
OUTBOX_RETENTION_DAYS=7
OUTBOX_RETRY_SCHEDULE=30,120,600,1800
OUTBOX_MAX_PARALLEL_DELIVERIES=5
AFRAH_NOTIFICATION_PHONE=



# ── MinIO Object Storage Configurations ────────────────────────────────────────
MINIO_ROOT_USER=zafaf_minio_admin
MINIO_ROOT_PASSWORD=zafaf_minio_secret
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=zafafworld-media
MINIO_APP_USER=zafaf_minio_admin
MINIO_APP_PASSWORD=zafaf_minio_secret
MINIO_ROOT_PREFIX=assets/uploads

# ── Headless WordPress Configuration ──────────────────────────────────────────
WP_HEADLESS_BASE_URL=https://blog.zafafworld.net

