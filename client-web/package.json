{
	"name": "zafaf-world",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"prebuild": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"postinstall": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide || true"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "3.1085.0",
		"@inlang/paraglide-js": "^2.18.2",
		"@inlang/paraglide-sveltekit": "0.16.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "latest",
		"dotenv": "17.4.2",
		"sharp": "0.35.3",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"@inlang/plugin-m-function-matcher": "2.2.6",
		"@inlang/plugin-message-format": "4.4.0"
	},
	"dependencies": {
		"isomorphic-dompurify": "3.18.0",
		"lucide-svelte": "^1.0.1",
		"zod": "^4.4.3"
	}
}