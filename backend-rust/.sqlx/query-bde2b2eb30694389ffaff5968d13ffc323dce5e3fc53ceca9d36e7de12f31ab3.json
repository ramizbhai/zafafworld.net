{
  "db_name": "PostgreSQL",
  "query": "SELECT r.id, r.vendor_id, r.requested_tier_id, r.status, r.admin_notes, r.created_at, r.updated_at, t.name as requested_tier_name\n             FROM vendor_subscription_requests r\n             JOIN subscription_tiers t ON r.requested_tier_id = t.id\n             WHERE r.vendor_id = $1\n             ORDER BY r.created_at DESC",
